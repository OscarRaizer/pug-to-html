{
  "name": "@alexbolt/pug-to-html-cli",
  "version": "1.0.1",
  "description": "A Node.js tool for automatically converting Pug templates in Vue Single File Components to HTML.",
  "keywords": [
    "pug",
    "vue",
    "vue-sfc",
    "html",
    "converter",
    "cli",
    "pug-to-html",
    "vue-template",
    "vue-cli"
  ],
  "homepage": "https://github.com/OscarRaizer/pug-to-html",
  "bugs": {
    "url": "https://github.com/OscarRaizer/pug-to-html/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OscarRaizer/pug-to-html.git"
  },
  "license": "MIT",
  "author": "Alex Bolt",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "pug-to-html": "bin/pug-to-html"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "lint": "eslint -c ./eslint.config.mjs \"./src*/**/*.{js,cjs,mjs,vue}\" --ignore-pattern \"bin/**\"",
    "format": "prettier --write --cache .",
    "format-check": "prettier --check --cache ."
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.2",
    "fast-glob": "^3.3.3",
    "pug": "^2.0.4",
    "pug-walk": "^1.1.8"
  },
  "devDependencies": {
    "@prettier/plugin-pug": "^3.4.2",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-unicorn": "62.0.0",
    "eslint-plugin-vue": "^10.7.0",
    "mocha": "^11.7.5",
    "prettier": "3.7.4",
    "vue-eslint-parser": "^10.2.0"
  },
  "sourceType": "module"
}
